# Google Gemini API key — get yours free at https://aistudio.google.com/apikey
# Copy this file to .env.local and fill in your key.
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gmail for sending reminder emails (Nodemailer).
# Generate an App Password at https://myaccount.google.com/apppasswords
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# LinkedIn OAuth 2.0 — for one-click posting.
# Create an app at https://www.linkedin.com/developers/apps
# Add "Sign In with LinkedIn using OpenID Connect" + "Share on LinkedIn" products.
# Set redirect URI to: http://localhost:3000/api/linkedin/callback
LINKEDIN_CLIENT_ID=your_client_id
LINKEDIN_CLIENT_SECRET=your_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/linkedin/callback

# EmailJS — daily reminder emails (optional; client-side, free tier).
# Create a service + template at https://dashboard.emailjs.com
# These are publishable keys, safe to expose in the browser (NEXT_PUBLIC_*).
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxx
GMAIL_USER=abc@gmail.com
GMAIL_APP_PASSWORD=yahan_wo_16_char_paste_karo
