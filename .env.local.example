# EmailJS — daily reminder emails (optional; client-side, free tier).
# Create a service + template at https://dashboard.emailjs.com
# These are publishable keys, safe to expose in the browser (NEXT_PUBLIC_*).
# Your template should accept: to_email, to_name, subject, post_date,
# best_time, post_preview, app_link.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxx
